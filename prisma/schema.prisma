generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id          Int          @id @default(autoincrement())
  name        String
  industry    String
  createdOn   DateTime     @default(now())
  jobs        Job[]
  submissions Submission[]

  @@map("clients")
}

model Job {
  id          BigInt       @id @default(autoincrement())
  clientId    Int
  createdBy   BigInt
  title       String
  description String
  skills      String
  location    String
  status      JobStatus
  experience  Int?
  createdOn   DateTime     @default(now())
  client      Client       @relation(fields: [clientId], references: [id])
  user        User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@map("jobs")
}

model Candidate {
  id               BigInt       @id @default(autoincrement())
  createdBy        BigInt
  name             String
  email            String       @unique
  mobNo            String
  currentCompany   String
  resume           String
  parsedResumeText String
  skills           String
  experience       Int
  createdOn        DateTime     @default(now())
  user             User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  submissions      Submission[]

  @@map("candidates")
}

model User {
  id          BigInt       @id @default(autoincrement())
  name        String
  email       String       @unique
  password    String
  mobNo       String
  role        UserRole
  createdOn   DateTime     @default(now())
  candidates  Candidate[]
  jobs        Job[]
  submissions Submission[]

  @@map("users")
}

model Submission {
  id          BigInt           @id @default(autoincrement())
  clientId    Int
  jobId       BigInt
  candidateId BigInt
  userId      BigInt
  status      SubmissionStatus
  score       Decimal          @db.Decimal(5, 2)
  comments    String
  createdOn   DateTime         @default(now())
  updatedOn   DateTime         @updatedAt
  candidate   Candidate        @relation(fields: [candidateId], references: [id])
  client      Client           @relation(fields: [clientId], references: [id])
  job         Job              @relation(fields: [jobId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@map("submissions")
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum SubmissionStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  OFFERED
  HIRED
}

enum UserRole {
  ADMIN
  RECRUITER
  USER
}
